{
  "name": "@fincasya/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "convex dev",
    "deploy": "convex deploy",
    "typecheck": "tsc --noEmit -p convex",
    "catalog:audit": "convex run admin:auditCatalogMappings",
    "catalog:fix": "convex run admin:fixCatalogMappingsFromProperties",
    "catalog:fix:dry": "convex run admin:fixCatalogMappingsFromProperties '{\"dryRun\": true}'",
    "catalog:sync": "convex run admin:syncCatalogFromMeta",
    "catalog:sync:dry": "convex run admin:syncCatalogFromMeta '{\"dryRun\": true}'"
  },
  "exports": {
    "./convex/_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    }
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.5",
    "better-auth": "^1.6.23",
    "convex": "^1.42.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5"
  }
}
